# API
API_KEY=your-secret-api-key

# PostgreSQL (Supabase connection string)
DATABASE_URL=postgresql+asyncpg://user:password@host:5432/postgres

# Redis
REDIS_URL=redis://localhost:6379
CACHE_TTL_SECONDS=3600

# OpenAI
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4

# Kroki
KROKI_BASE_URL=https://kroki.io

# Mermaid fallback
MERMAID_INK_BASE_URL=https://mermaid.ink

# x402 (seller/resource server)
X402_ENABLED=false
X402_FACILITATOR_URL=https://x402.org/facilitator
X402_NETWORK=eip155:84532
X402_PAY_TO=0xYourBaseWalletAddress
X402_PRICE=$0.01
X402_BUILDER_CODE=bc_yourbuildercode

# x402 buyer test client (for end-to-end payment verification)
X402_PAID_ENDPOINT_URL=http://127.0.0.1:8000/paid/diagrams/generate
EVM_PRIVATE_KEY=0xyourbuyerprivatekey
